# ── Shopify (private app for one store) ─────────────────────────────────
# Store domain, e.g. italian-bear-chocolate.myshopify.com
SHOPIFY_SHOP_DOMAIN=

# OPTION A — Dev Dashboard app (current Shopify flow):
# Client ID + secret from the app's Settings page. The app exchanges these
# for short-lived access tokens automatically (client credentials grant).
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# OPTION B — legacy admin-created custom app: permanent token (shpat_...).
# Leave blank when using Option A.
SHOPIFY_ADMIN_ACCESS_TOKEN=

# Webhook signing secret. Dev Dashboard app: same as SHOPIFY_CLIENT_SECRET.
# Legacy custom app: the "API secret key".
SHOPIFY_WEBHOOK_SECRET=
# Admin API version (latest stable)
SHOPIFY_API_VERSION=2026-07

# ── Supabase ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — server only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# ── Push notifications (OneSignal) ──────────────────────────────────────
NEXT_PUBLIC_ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# ── App ──────────────────────────────────────────────────────────────────
# Public URL of this deployment, e.g. https://orders.italianbear.co.uk
NEXT_PUBLIC_APP_URL=
# Random secret; Vercel cron requests must send it as Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
# Set to "true" to enable the demo-data banner + seed guard rails
DEMO_MODE=false
